#!/usr/bin/env bash
# tstack setup — symlinks commands + agents to ~/.claude/
set -euo pipefail

TSTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUDE_DIR="$HOME/.claude"

# Ensure target directories exist
mkdir -p "$CLAUDE_DIR/commands" "$CLAUDE_DIR/agents" "$CLAUDE_DIR/skills"

echo "tstack setup — installing from $TSTACK_DIR"
echo ""

# Symlink commands
COMMAND_COUNT=0
for src in "$TSTACK_DIR/commands"/tstack-*.md; do
  [ -f "$src" ] || continue
  filename="$(basename "$src")"
  dst="$CLAUDE_DIR/commands/$filename"
  if [ -L "$dst" ]; then
    rm "$dst"
  elif [ -f "$dst" ]; then
    echo "  SKIP $filename (non-symlink file exists at $dst — remove manually)"
    continue
  fi
  ln -s "$src" "$dst"
  echo "  ✓ commands/$filename"
  COMMAND_COUNT=$((COMMAND_COUNT + 1))
done

# Symlink agents
AGENT_COUNT=0
for src in "$TSTACK_DIR/agents"/tstack-*.md; do
  [ -f "$src" ] || continue
  filename="$(basename "$src")"
  dst="$CLAUDE_DIR/agents/$filename"
  if [ -L "$dst" ]; then
    rm "$dst"
  elif [ -f "$dst" ]; then
    echo "  SKIP $filename (non-symlink file exists at $dst — remove manually)"
    continue
  fi
  ln -s "$src" "$dst"
  echo "  ✓ agents/$filename"
  AGENT_COUNT=$((AGENT_COUNT + 1))
done

# Symlink skills (directory-level symlinks)
SKILL_COUNT=0
for src in "$TSTACK_DIR/skills"/tstack-*/; do
  [ -d "$src" ] || continue
  dirname="$(basename "$src")"
  dst="$CLAUDE_DIR/skills/$dirname"
  if [ -L "$dst" ]; then
    rm "$dst"
  elif [ -d "$dst" ]; then
    echo "  SKIP $dirname (non-symlink directory exists at $dst — remove manually)"
    continue
  fi
  ln -s "$src" "$dst"
  echo "  ✓ skills/$dirname"
  SKILL_COUNT=$((SKILL_COUNT + 1))
done

echo ""
echo "Installed: $COMMAND_COUNT commands, $AGENT_COUNT agents, $SKILL_COUNT skills"
echo ""
echo "Available commands:"
ls "$CLAUDE_DIR/commands"/tstack-*.md 2>/dev/null | while read -r f; do
  echo "  /$(basename "$f" .md)"
done
echo ""
echo "Available skills:"
ls -d "$CLAUDE_DIR/skills"/tstack-*/ 2>/dev/null | while read -r d; do
  echo "  $(basename "$d")"
done
echo ""
echo "Run /tstack-help in Claude Code to see everything."
